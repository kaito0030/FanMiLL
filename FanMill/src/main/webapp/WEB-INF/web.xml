<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
            http://xmlns.jcp.org/xml/ns/javaee
            http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	version="4.0">

	<!-- アプリ名 -->
	<display-name>FanMILL</display-name>

	<!-- 初期表示 -->
	<welcome-file-list>

		<welcome-file>login</welcome-file>

	</welcome-file-list>

	<!-- セッション -->
	<session-config>

		<session-timeout>
			30
		</session-timeout>

	</session-config>

	<!-- エラーページ -->

	<error-page>

		<exception-type>
			java.lang.Exception
		</exception-type>

		<location>
			/WEB-INF/jsp/error/error.jsp
		</location>

	</error-page>

	<error-page>

		<error-code>404</error-code>

		<location>
			/WEB-INF/jsp/error/error.jsp
		</location>

	</error-page>

	<error-page>

		<error-code>500</error-code>

		<location>
			/WEB-INF/jsp/error/error.jsp
		</location>

	</error-page>

</web-app>